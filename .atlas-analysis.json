  "keyFeatures": [
    "Zero-config prompt injection detection with moderate preset",
    "Chainable Zod-inspired API for fluent configuration",
    "Five threat types: instruction override, role manipulation, delimiter injection, system prompt leak, encoding attacks",
    "Fast pattern-based detection (<0.5ms p99 latency)",
    "Flexible threat actions: block, sanitize, warn, or allow",
    "TypeScript-first with excellent type inference",
    "Tiny bundle size (<10KB minified + gzipped)",
    "ReDoS-safe patterns with iterative sanitization",
    "Safe parsing with discriminated union results"
  ],
  "publicApiSurface": [
    "vard(input?: string)",
    "vard.safe(input: string)",
    "vard.strict()",
    "vard.moderate()",
    "vard.lenient()",
    "v (alias)",
    "createVard()",
    "VardBuilder.parse(input: string)",
    "VardBuilder.safeParse(input: string)",
    "VardBuilder.delimiters(delims: string[])",
    "VardBuilder.pattern(regex: RegExp, severity?: number, type?: ThreatType)",
    "VardBuilder.patterns(patterns: Pattern[])",
    "VardBuilder.maxLength(length: number)",
    "VardBuilder.threshold(value: number)",
    "VardBuilder.block(threat: ThreatType)",
    "VardBuilder.sanitize(threat: ThreatType)",
    "VardBuilder.warn(threat: ThreatType)",
    "VardBuilder.allow(threat: ThreatType)",
    "VardBuilder.onWarn(callback: (threat: Threat) => void)",
    "PromptInjectionError.getUserMessage(locale?: 'en' | 'no')",
    "PromptInjectionError.getDebugInfo()",
    "Types: ThreatType, ThreatAction, Threat, VardResult, Pattern, VardConfig, PresetName, CallableVard"
